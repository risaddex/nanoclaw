

# Added by skill
ASSISTANT_HAS_OWN_NUMBER=

# --- Serena HTTP Bridge (optional) ---
# Start Serena via docker-compose: docker compose up -d
# Then set SERENA_MCP_URL so agent containers can reach it.
# IDE (VSCode/Cursor): configure MCP server URL as http://localhost:8765/mcp
#
# URL used by agent containers to reach Serena (via host.docker.internal)
# SERENA_MCP_URL=http://host.docker.internal:8765/mcp
#
# Projects available to agents for Bash (tests/builds).
# Must match the volume mounts in docker-compose.yml.
# Format: "name:/host/path,name2:/host/path2"
# SERENA_PROJECT_PATHS=nanoclaw:/home/user/Work/nanoclaw
#
# SERENA_START_CMD is NOT needed when using docker-compose to manage Serena.

TZ=America/Sao_Paulo